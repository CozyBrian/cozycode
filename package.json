{
  "name": "cozycode",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/desktop build",
    "tui": "bun apps/tui/src/index.tsx",
    "typecheck": "tsc -p packages/protocol/tsconfig.json && tsc -p packages/commands/tsconfig.json && tsc -p packages/core/tsconfig.json && tsc -p apps/desktop/tsconfig.json && tsc -p apps/tui/tsconfig.json",
    "test": "bun test",
    "agent": "bun packages/core/scripts/agent-run.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "@types/node": "26.1.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
