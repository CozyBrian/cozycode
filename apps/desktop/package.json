{
  "name": "@cozycode/desktop",
  "productName": "CozyCode",
  "version": "0.1.0",
  "description": "A calm, native-feeling coding agent for macOS.",
  "author": "CozyBrian",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json",
    "test:store": "node --disable-warning=ExperimentalWarning --test test/session-store.node-test.mjs",
    "icon": "bun run scripts/build-icon.mjs",
    "pack:mac": "bun run icon && bun run build && electron-builder --config electron-builder.yml --mac --arm64 --dir",
    "dist:mac": "bun run icon && bun run build && electron-builder --config electron-builder.yml --mac dmg zip --arm64 --publish never"
  },
  "dependencies": {
    "@cozycode/commands": "workspace:*",
    "@cozycode/core": "workspace:*",
    "@cozycode/design-system": "workspace:*",
    "@cozycode/protocol": "workspace:*",
    "@lydell/node-pty": "^1.1.0",
    "@pierre/diffs": "1.2.12",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.500.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.35.3",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.0.0",
    "vite": "^7.0.0"
  },
  "optionalDependencies": {
    "@lydell/node-pty-darwin-arm64": "1.1.0"
  }
}
